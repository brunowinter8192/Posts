# WHITELIST MODE — everything is private by default.
# To publish an article, add an explicit un-ignore rule set for it below.

/*
.DS_Store

# always-ignored even under whitelisted dirs (build/install output)
node_modules/
dist/
.astro/

# --- infrastructure (always public) ---
!/.gitignore

# --- published articles (explicit whitelist, one rule set per article) ---
!/articles/
/articles/*
!/articles/rag-eval/
/articles/rag-eval/*
!/articles/rag-eval/rageval-notes.md

# --- Astro/Cactus site scaffold (public) ---
!/package.json
!/package-lock.json
!/tsconfig.json
!/astro.config.mjs
!/tailwind.config.ts
!/LICENSE
!/src/
!/src/**
!/public/
!/public/**
!/.github/
/.github/*
!/.github/workflows/
/.github/workflows/*
!/.github/workflows/deploy.yml
